-- ============================================================
-- z_pda_private_mac_registration.script
-- Registers the Private Messages app with MAC framework
-- ============================================================

-- CRITICAL: This file name starts with 'z_' to ensure it loads AFTER
-- the MAC framework is initialized

function on_game_start()
    -- Register our Private Messages app with MAC
    if mac_mcm and mac_mcm.add_app then
        mac_mcm.add_app("pda_private", {
            name = "st_pda_private_tab",  -- Localization string ID
            texture = "ui_pda_private_app",    -- Icon texture name
            tab = "eptPrivateMessages",        -- MUST match the dxml button ID
            func = pda_private_tab.get_ui      -- Function that returns the UI
        })
        
        printf("! [Private Messages] Successfully registered with MAC framework")
    else
        printf("! [Private Messages] ERROR: MAC framework not found!")
        printf("! [Private Messages] Make sure MAC (Mod App Creator) is installed")
    end
end

