<?xml version="1.0" encoding="windows-1251" ?>
<pda_private>
    <private_pda x="0" y="0" width="1024" height="768">
        <state x="0" y="0" width="1024" height="768"/>
        
        <!-- Main content area positioned to match PDA tabs -->
        <info x="15" y="90" width="970" height="618">
            <!-- Background for the entire info area -->
            <background x="0" y="0" width="970" height="618" stretch="1">
                <texture r="20" g="20" b="20" a="200">ui_inGame2_hint_wnd_main_window</texture>
            </background>
            
            <!-- Border lines to frame the info area -->
            <auto_frameline x="0" y="0" width="970" height="1" vertical="0">
                <texture>ui_inGame2_pda_line_horizontal</texture>
            </auto_frameline>
            <auto_frameline x="0" y="618" width="970" height="1" vertical="0">
                <texture>ui_inGame2_pda_line_horizontal</texture>
            </auto_frameline>
            <auto_frameline x="0" y="0" width="1" height="618" vertical="1">
                <texture>ui_inGame2_pda_line_vertical</texture>
            </auto_frameline>
            <auto_frameline x="970" y="0" width="1" height="618" vertical="1">
                <texture>ui_inGame2_pda_line_vertical</texture>
            </auto_frameline>
            
            <!-- Vertical divider between left list and chat area -->
            <auto_frameline x="240" y="5" width="1" height="608" vertical="1">
                <texture>ui_inGame2_pda_line_vertical</texture>
            </auto_frameline>
            
            <!-- LEFT PANE: Contact list (240px wide) -->
            <list_bg x="5" y="5" width="230" height="608" stretch="1">
                <texture r="25" g="25" b="25" a="220">ui_inGame2_hint_wnd_main_window</texture>
            </list_bg>
            
            <!-- Contact list header -->
            <list_header x="10" y="10" width="220" height="25">
                <text font="letterica18" r="200" g="200" b="200" a="255" align="l" vert_align="c">CONTACTS</text>
            </list_header>
            
            <message_list x="10" y="40" width="220" height="560" item_height="55" can_select="1"/>
            
            <!-- RIGHT PANE: Chat area (720px wide - full remaining space) -->
            <description x="245" y="5" width="720" height="608">
                <!-- Background for the chat area -->
                <background x="0" y="0" width="720" height="608" stretch="1">
                    <texture r="30" g="30" b="30" a="200">ui_inGame2_hint_wnd_main_window</texture>
                </background>
                
                <!-- Empty state message -->
                <empty_state x="0" y="270" width="720" height="30">
                    <text font="letterica25" r="100" g="100" b="100" a="255" align="c" vert_align="c">SELECT A CONTACT</text>
                </empty_state>

                <!-- EXPANDED HEADER with integrated stats (120px tall) -->
                <header_bg x="0" y="0" width="720" height="120" stretch="1">
                    <texture r="40" g="40" b="40" a="220">ui_inGame2_hint_wnd_main_window</texture>
                </header_bg>
                
                <!-- Separator line under header -->
                <auto_frameline x="0" y="120" width="720" height="1" vertical="0">
                    <texture>ui_inGame2_pda_line_horizontal</texture>
                </auto_frameline>

                <!-- NPC Portrait -->
                <image_container x="5" y="3" width="64" height="64">
                    <image x="0" y="0" width="64" height="64" stretch="1">
                        <texture>ui_inGame2_Neutral_1</texture>
                    </image>
                    <image_frame x="0" y="0" width="64" height="64" stretch="1">
                        <texture>ui_inGame2_PDA_Frame</texture>
                    </image_frame>
                </image_container>
                
                <!-- Status indicator dot -->
                <status_indicator x="60" y="55" width="12" height="12" stretch="1">
                    <texture r="100" g="100" b="100" a="200">ui_inGame2_hint_wnd_main_window</texture>
                </status_indicator>

                <!-- NPC Name -->
                <chat_header_name x="75" y="8" width="400" height="25">
                    <text font="letterica25" r="255" g="200" b="50" a="255" align="l" vert_align="c"/>
                </chat_header_name>
                
                <!-- Faction badge -->
                <faction_badge x="75" y="32" width="300" height="18">
                    <text font="letterica16" r="200" g="200" b="200" a="255" align="l" vert_align="c"/>
                </faction_badge>
                
                <!-- Message count -->
                <message_count x="480" y="8" width="230" height="20">
                    <text font="letterica16" r="150" g="150" b="150" a="255" align="r" vert_align="c"/>
                </message_count>
                
                <!-- Last contact time -->
                <last_seen x="480" y="28" width="230" height="18">
                    <text font="letterica16" r="130" g="130" b="130" a="255" align="r" vert_align="c"/>
                </last_seen>
                
                <!-- Divider between header and stats -->
                <auto_frameline x="75" y="55" width="635" height="1" vertical="0">
                    <texture>ui_inGame2_pda_line_horizontal</texture>
                </auto_frameline>
                
                <!-- Left column - SUPER TIGHT spacing -->
                <stat_relation_label x="75" y="63" width="55" height="16">
                    <text font="letterica16" r="140" g="140" b="140" a="255" align="l" vert_align="c">Relation:</text>
                </stat_relation_label>
                <stat_relation_value x="110" y="63" width="100" height="16">
                    <text font="letterica16" r="255" g="255" b="255" a="255" align="l" vert_align="c"/>
                </stat_relation_value>
                
                <stat_goodwill_label x="75" y="82" width="55" height="16">
                    <text font="letterica16" r="140" g="140" b="140" a="255" align="l" vert_align="c">Goodwill:</text>
                </stat_goodwill_label>
                <stat_goodwill_value x="110" y="82" width="100" height="16">
                    <text font="letterica16" r="255" g="255" b="255" a="255" align="l" vert_align="c"/>
                </stat_goodwill_value>
                
                <stat_rank_label x="75" y="101" width="55" height="16">
                    <text font="letterica16" r="140" g="140" b="140" a="255" align="l" vert_align="c">Rank:</text>
                </stat_rank_label>
                <stat_rank_value x="110" y="101" width="100" height="16">
                    <text font="letterica16" r="255" g="255" b="255" a="255" align="l" vert_align="c"/>
                </stat_rank_value>
                
                <!-- Scrollbar for messages -->
                <scrollbar x="0" y="130" width="720" height="432" right_ident="0" left_ident="0" top_indent="0" bottom_indent="0" vert_interval="10" always_show_scroll="1">
                    <texture>ui_inGame2_scroll_background</texture>
                </scrollbar>

                <!-- Bottom-anchored reply trigger -->
                <reply_trigger_btn x="10" y="568" width="700" height="30" stretch="1" can_focus="1">
                    <texture_e>ui_inGame2_hint_wnd_main_window</texture_e>
                    <texture_t>ui_inGame2_hint_wnd_main_window</texture_t>
                    <texture_h>ui_inGame2_hint_wnd_main_window</texture_h>
                    <text font="letterica16" align="l" vert_align="c" x="12" y="0" complex_mode="1" />
                    <!-- Pronounced highlight color -->
                    <text_color>
                        <e r="150" g="150" b="150" a="255"/>
                        <h r="100" g="255" b="100" a="255"/>
                        <t r="50" g="200" b="50" a="255"/>
                    </text_color>
                </reply_trigger_btn>
                
                <!-- Message rows: reusable lanes -->
                <message_lane_npc x="0" y="0" width="600" height="50" stretch="1">
                    <bubble_bg x="8" y="0" width="470" height="50" stretch="1">
                        <texture r="52" g="52" b="52" a="190">ui_inGame2_hint_wnd_main_window</texture>
                    </bubble_bg>
                    <text_box x="20" y="6" width="446" height="20" complex_mode="1">
                         <text font="letterica16" r="220" g="220" b="220" a="255"/>
                    </text_box>
                </message_lane_npc>

                <message_lane_player x="0" y="0" width="500" height="50" stretch="1">
                    <!-- Moved left significantly (x="160" instead of "222") -->
                    <bubble_bg x="100" y="0" width="470" height="50" stretch="1">
                        <texture r="45" g="70" b="45" a="180">ui_inGame2_hint_wnd_main_window</texture>
                    </bubble_bg>
                    <text_box x="110" y="6" width="446" height="20" complex_mode="1">
                         <text font="letterica16" r="200" g="255" b="200" a="255"/>
                    </text_box>
                </message_lane_player>
                
                <!-- Choice buttons -->
                <choice_btn x="110" y="0" width="470" height="30" stretch="1" can_focus="1">
                    <texture_e>ui_inGame2_hint_wnd_main_window</texture_e>
                    <texture_t>ui_inGame2_hint_wnd_main_window</texture_t>
                    <texture_h>ui_inGame2_hint_wnd_main_window</texture_h>
                    <text font="letterica16" align="l" vert_align="c" x="15" y="0" complex_mode="1" />
                    <!-- Pronounced highlight color -->
                    <text_color>
                        <e r="220" g="220" b="220" a="255"/>
                        <h r="100" g="255" b="100" a="255"/>
                        <t r="50" g="200" b="50" a="255"/>
                    </text_color>
                </choice_btn>
            </description>
        </info>
    </private_pda>
</pda_private>
