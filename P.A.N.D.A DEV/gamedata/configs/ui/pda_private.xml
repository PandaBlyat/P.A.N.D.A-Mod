<?xml version="1.0" encoding="windows-1251" ?>
<pda_private>
    <private_pda x="0" y="0" width="1024" height="768">
        <state x="0" y="0" width="1024" height="768"/>
        
        <!-- Main content area positioned to match PDA tabs -->
        <info x="15" y="90" width="640" height="618">
            <!-- Background for the entire info area (subtle) -->
            <background x="0" y="0" width="640" height="618" stretch="1">
                <texture r="20" g="20" b="20" a="200">ui_inGame2_hint_wnd_main_window</texture>
            </background>
            <button x="360" y="10" width="20" height="20" id="btn_close">
				<texture>ui_inGame2_close_button</texture>
			</button>
            <!-- Border lines to frame the info area (like the npc_pda example) -->
            <auto_frameline x="0" y="0" width="640" height="1" vertical="0">
                <texture>ui_inGame2_pda_line_horizontal</texture>
            </auto_frameline>
            <auto_frameline x="0" y="618" width="640" height="1" vertical="0">
                <texture>ui_inGame2_pda_line_horizontal</texture>
            </auto_frameline>
            <auto_frameline x="0" y="0" width="1" height="618" vertical="1">
                <texture>ui_inGame2_pda_line_vertical</texture>
            </auto_frameline>
            <auto_frameline x="640" y="0" width="1" height="618" vertical="1">
                <texture>ui_inGame2_pda_line_vertical</texture>
            </auto_frameline>
            
            <!-- Vertical divider between left list and right chat (like the center line) -->
            <auto_frameline x="240" y="5" width="1" height="608" vertical="1">
                <texture>ui_inGame2_pda_line_vertical</texture>
            </auto_frameline>
            
            <!-- LEFT PANE: Contact list with background -->
            <list_bg x="5" y="5" width="230" height="600" stretch="1">
                <texture>ui_inGame2_hint_wnd_main_window</texture>
            </list_bg>
            <message_list x="10" y="10" width="220" height="590" item_height="50" can_select="1"/>
            
            <!-- RIGHT PANE: Chat area -->
            <description x="245" y="5" width="390" height="608">
                <!-- Background for the chat area -->
                <background x="0" y="0" width="390" height="608" stretch="1">
                    <texture r="30" g="30" b="30" a="200">ui_inGame2_hint_wnd_main_window</texture>
                </background>
                
                <!-- Empty state message (centered) -->
                <empty_state x="0" y="250" width="390" height="30">
                    <text font="letterica25" r="100" g="100" b="100" a="255" align="c" vert_align="c">SELECT A CONTACT</text>
                </empty_state>

                <!-- Header bar with contact name and image -->
                <header_bg x="0" y="0" width="390" height="64" stretch="1">
                    <texture r="150" g="150" b="150" a="100">ui_inGame2_hint_wnd_main_window</texture>
                </header_bg>

                <image_container x="0" y="0" width="64" height="64">
                    <image x="0" y="0" width="64" height="64" stretch="1">
                        <texture>ui_pda_private_app</texture> 
                    </image>
                    <image_frame x="0" y="0" width="64" height="64" stretch="1">
                        <texture>ui_inGame2_PDA_Frame</texture>
                    </image_frame>
                </image_container>

                <chat_header_name x="75" y="20" width="300" height="20">
                    <text font="letterica25" r="255" g="200" b="50" a="255" align="l" vert_align="c"/>
                </chat_header_name>
                
                <!-- Scrollbar with visible track -->
                <scrollbar x="0" y="75" width="390" height="533" right_ident="0" left_ident="0" top_indent="0" bottom_indent="0" vert_interval="12" always_show_scroll="1">
                    <texture>ui_inGame2_scroll_background</texture>
                </scrollbar>
                
                <!-- Message bubbles (wider to fill space) -->
                <bubble_npc x="10" y="0" width="370" height="50" stretch="1">
                    <texture r="100" g="100" b="100" a="180">ui_inGame2_hint_wnd_main_window</texture>
                    <text_box x="10" y="5" width="350" height="20" complex_mode="1">
                         <text font="letterica16" r="220" g="220" b="220" a="255"/>
                    </text_box>
                </bubble_npc>

                <bubble_player x="10" y="0" width="370" height="50" stretch="1">
                    <texture r="80" g="120" b="80" a="180">ui_inGame2_hint_wnd_main_window</texture>
                    <text_box x="10" y="5" width="350" height="20" complex_mode="1">
                         <text font="letterica16" r="255" g="255" b="255" a="255"/>
                    </text_box>
                </bubble_player>
                
                <!-- Choice buttons (full width) -->
                <choice_btn x="10" y="0" width="370" height="35" stretch="1">
                    <texture_e r="60" g="60" b="60" a="255">ui_inGame2_hint_wnd_main_window</texture_e>
                    <texture_t r="80" g="80" b="80" a="255">ui_inGame2_hint_wnd_main_window</texture_t>
                    <texture_h r="100" g="100" b="100" a="255">ui_inGame2_hint_wnd_main_window</texture_h>
                    
                    <text font="letterica16" align="l" vert_align="c" x="15" y="0" complex_mode="1">
                        <text_color r="255" g="200" b="50" a="255"/>
                        <text_color_h r="255" g="255" b="255" a="255"/>
                        <text_color_t r="150" g="150" b="150" a="255"/>
                    </text>
                </choice_btn>
            </description>
        </info>
    </private_pda>
</pda_private>